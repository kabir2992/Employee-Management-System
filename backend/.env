EMAIL_USER=YOUR EMAIL ADDRESS
EMAIL_PASS=YOUR EMAIL ADDRESS PASSWORD BY GOOGLE TO SEND EMAIL
JWT_SECRET=YOUR OWN SECRET KEY
JWT_EXPIRES=EXPIRE TIME EG. 1d
