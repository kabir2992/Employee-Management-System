PORT=PORT ON WHICH YOU WANNA RUN
MONGO_USER=MONGODB USERNAME
MONGO_PASS=MONGODB PASSWORD
MONGO_URI=YOUR MONGODB URL WITH USERNAME,PASSWORD,CLUSTER NAME AND DATABASE NAME
EMAIL_USER=YOUR EMAIL ADDRESS
EMAIL_PASS=YOUR EMAIL ADDRESS PASSWORD BY GMAIL
JWT_SECRET=YOUR OWN SECRET KEY EG. myKEY12
JWT_EXPIRES=YOUR EXPIRE TIME EG. 1d
